# Optional. Only needed for GitHub Pages PROJECT sites served from a subpath.
# Example: if your repo is github.com/you/senda, the site lives at /senda/ :
#   VITE_BASE=/senda/
#
# Netlify, Vercel, custom domains, and GitHub user/org pages can leave this unset.
#
# NOTE: There is no API key here. Senda is bring-your-own-key — you paste your
# Gemini key inside the app (Settings), and it is stored only in your browser.
# VITE_BASE=/senda/
